          "width": 28, "height": 44,
          "color": "0xcc8844",
          "label": "Old Man",
          "interactable": true,
          "blocks": true,
          "lookMessage": "An old man with a long grey beard.",
          "talkMessage": "He grunts and looks away.",
          "dialogTree": {
            "start": {
              "text": "Evening, stranger. Not many make it to this old manor.",
              "options": [
                { "text": "Who are you?", "next": "who" },
                { "text": "What is this place?", "next": "place" },
                { "text": "Goodbye.", "next": null }
              ]
            },
            "who": {
              "text": "I'm the caretaker.",
              "options": [
                { "text": "How long have you been here?", "next": "how_long" },
                { "text": "Seen anything strange?", "next": "strange" },
                { "text": "I should go.", "next": null }
              ]
            },
            "how_long": {
              "text": "Thirty years. Time moves different in a place like this.",
              "options": [
                { "text": "What do you mean?", "next": "time_meaning" },
                { "text": "I see. Goodbye.", "next": null }
              ]
            },
            "time_meaning": {
              "text": "You'll see.",
              "options": [
                { "text": "That's unsettling.", "next": "unsettling" },
                { "text": "I'll keep an eye out.", "next": null }
              ]
            },
            "unsettling": {
              "text": "Heh. You get used to it.",
              "options": [
                { "text": "...", "next": null }
              ]
            },
            "strange": {
              "text": "The study gives me the creeps.",
              "options": [
                { "text": "Uhh... okay.", "next": null }
              ]
            },
            "place": {
              "text": "Old Manor Blackwood. Been standing longer than anyone remembers. Full of secrets.",
              "options": [
                { "text": "What kind of secrets?", "next": "secrets" },
                { "text": "I'd better explore.", "next": null }
              ]
            },
            "secrets": {
              "text": "Things that hum in the walls. Something awful happened here.",
              "options": [
                { "text": "What happened?", "next": "secrets2" },
                { "text": "Oh... okay.", "next": null }
              ]
            },
            "secrets2": {
              "text": "Fire. They burned her.",
              "options": [
                { "text": "That sounds awful, indeed.", "next": "secrets3" }
              ]
            },
            "secrets3": {
              "text": "Yes. But it happened a loooong time ago.",
              "options": [
                { "text": "I really hope so.", "next": null }
              ]
            }
          }
        }
